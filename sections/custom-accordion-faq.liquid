<style>
  #custom-accordion-faq-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.background_color }};
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__layout {
    max-width: 1000px;
    margin: 0 auto;
    padding: 50px 20px;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__title {
    font-size: 50px;
    font-weight: 500;
    font-family: 'Founders Grotesk', sans-serif;
    margin:0px;
    text-align: left;
    color: {{ section.settings.title_color }};
  }
  @media only screen and (max-width: 749px) {
    #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__title {
      font-size: 35px;
      margin-bottom: 0px;
    }
  }

  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__item {
    border-bottom: 1px solid var(--faq-border-color, #000000);
  }

  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 24px 0;
    margin: 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'Founders Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
    color: inherit;
  }
  @media only screen and (max-width: 749px) {
    #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question {
      font-size: 18px;
      padding: 18px 0;
    }
  }

  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question-text {
    flex: 1 1 auto;
  }

  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__icon {
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    display: inline-flex;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Show plus when closed, minus when open */
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__icon--minus {
    display: none;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question[aria-expanded="true"] .custom-accordion-faq__icon--plus {
    display: none;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question[aria-expanded="true"] .custom-accordion-faq__icon--minus {
    display: inline-flex;
  }

  /* Smooth drop-down using grid-template-rows transition */
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__question[aria-expanded="true"] + .custom-accordion-faq__answer {
    grid-template-rows: 1fr;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__answer-inner {
    overflow: hidden;
  }
  #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__answer-text {
    padding: 0 0 24px 0;
    font-family: 'Founders Grotesk', sans-serif;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.5;
  }
  @media only screen and (max-width: 749px) {
    #custom-accordion-faq-{{ section.id }} .custom-accordion-faq__answer-text {
      font-size: 15px;
      padding-left: 0;
    }
  }
</style>

{%- comment -%}
  Variant-aware accordion FAQ.
  Every variant's content is pre-rendered (keyed by data-variant-id) and all but the
  current one are hidden. A small delegated script (bottom of the section) swaps which
  one is visible when the shopper picks a different variant — no page reload. Questions
  and answers are pulled from the variant's `custom.faqs` metaobject (fields question_1
  / answer_1 … question_12 / answer_12); each falls back to the matching FAQ item block
  configured in the theme editor when the metaobject field is blank. Variant selection
  is detected via:
    - bundle-subscription buy box: [data-variant-radio] / [data-variant-id]
      (that template dispatches NO theme:variant:change — see snippets/buy-box-bundle-subscription.liquid)
    - standard product templates: theme:variant:change / shapes:product:variantchange events
    - URL ?variant=ID on load
{%- endcomment -%}

{%- liquid
  assign faq_current_variant = product.selected_or_first_available_variant
  assign faq_wrapper_id = 'custom-accordion-faq-' | append: section.id
-%}

<section
  class="custom-accordion-faq"
  id="{{ faq_wrapper_id }}"
  data-variant-switcher
  data-slide-selector=".custom-accordion-faq__variant"
  data-question-selector=".custom-accordion-faq__question"
>
  <div class="custom-accordion-faq__layout">
    {%- if section.settings.title != blank -%}
      <h2 class="custom-accordion-faq__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- for variant in product.variants -%}
      {%- liquid
        # Pull questions/answers from the variant metaobject metafield when present,
        # otherwise fall back to the section's FAQ item blocks.
        assign faq_metaobject = variant.metafields.custom.faqs.value
      -%}
      <div
        class="custom-accordion-faq__variant"
        data-variant-id="{{ variant.id }}"
        {% unless variant.id == faq_current_variant.id %}
          style="display: none;"
        {% endunless %}
      >
        <div class="custom-accordion-faq__items">
          {%- for block in section.blocks -%}
            {%- liquid
              # `question_N` (single line text) and `answer_N` (richtext) keyed by block order.
              assign faq_question_key = 'question_' | append: forloop.index
              assign faq_answer_key = 'answer_' | append: forloop.index

              assign faq_question = block.settings.question
              assign faq_answer = block.settings.answer

              if faq_metaobject != blank and faq_metaobject[faq_question_key] != blank
                assign faq_question = faq_metaobject[faq_question_key]
              endif
              if faq_metaobject != blank and faq_metaobject[faq_answer_key] != blank
                assign faq_answer = faq_metaobject[faq_answer_key] | metafield_tag
              endif
            -%}
            {%- if faq_question != blank -%}
              <div
                class="custom-accordion-faq__item"
                style="--faq-border-color: {{ block.settings.border_color }};"
                {{ block.shopify_attributes }}
              >
                <button
                  type="button"
                  class="custom-accordion-faq__question"
                  aria-expanded="false"
                  aria-controls="faq-answer-{{ section.id }}-{{ variant.id }}-{{ block.id }}"
                >
                  <span class="custom-accordion-faq__question-text">{{ faq_question }}</span>
                  <span class="custom-accordion-faq__icon custom-accordion-faq__icon--plus" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <line x1="12" y1="4" x2="12" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                  </span>
                  <span class="custom-accordion-faq__icon custom-accordion-faq__icon--minus" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                  </span>
                </button>
                <div
                  class="custom-accordion-faq__answer"
                  id="faq-answer-{{ section.id }}-{{ variant.id }}-{{ block.id }}"
                  role="region"
                >
                  <div class="custom-accordion-faq__answer-inner">
                    <div class="custom-accordion-faq__answer-text">{{ faq_answer }}</div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script src="{{ 'variant-section-switcher.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Accordion FAQ",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FBF5E1"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#C5273C"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question goes here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer goes here.</p>"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border bottom color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Accordion FAQ",
      "blocks": [{ "type": "faq_item" }, { "type": "faq_item" }, { "type": "faq_item" }]
    }
  ]
}
{% endschema %}
