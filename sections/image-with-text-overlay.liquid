              },
              {
                "value": "hexagon",
                "label": "t:common.options.hexagon.label",
                "group": "t:common.groups.polygons"
              }, {
                "value": "heptagon",
                "label": "t:common.options.heptagon.label",
                "group": "t:common.groups.polygons"
              }, {
                "value": "octagon",
                "label": "t:common.options.octagon.label",
                "group": "t:common.groups.polygons"
              }, {
                "value": "nonagon",
                "label": "t:common.options.nonagon.label",
                "group": "t:common.groups.polygons"
