{% liquid
  assign style = section.settings.style
  assign mobile_style = section.settings.mobile_style
  assign height = section.settings.height

  if height == 'pt-screen-height'
    assign height = 'pt-screen-height first-section:pt-screen-height-less-header-group'
  endif

  if height == 'natural'
    assign crop = 'object-wrapper-none'
  else
    assign crop = 'object-wrapper ' | append: height
  endif
%}

{%- comment -%} CUSTOM – Image with text overlay. All section typography/colors in this block only. {%- endcomment -%}
<style> 
 
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-body
    , #shopify-section-{{ section.id }}
    .iwto-body p {
      font-size: {{ section.settings.body_font_size_desktop | default: 20 }}px; 
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-body
    , #shopify-section-{{ section.id }}
    .iwto-body p {
      font-size: {{ section.settings.body_font_size_mobile | default: 18 }}px; 
    }
  }
  /* Subheader – overlap title, higher z-index */
  #shopify-section-{{ section.id }} .iwto-subheader {
    font-family: 'Founders Grotesk', sans-serif;
    position: relative;
    z-index: 2;
    margin-bottom: -0.4em;
  }
  #shopify-section-{{ section.id }} .iwto-badge {
    position: relative;
    z-index: 2;
    margin-bottom: -0.5rem;
  }
  #shopify-section-{{ section.id }} .iwto-heading {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-heading {
      font-size: {{ section.settings.header_font_size | default: 80 }}px;
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-heading {
      font-size: {{ section.settings.header_font_size_mobile | default: 40 }}px;
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-subheader {
      font-size: {{ section.settings.subheader_font_size_desktop | default: 20 }}px;
      line-height: 25px;
      max-width: {{ section.settings.subheader_max_width_desktop | default: 500 }}px;
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-subheader {
      font-size: {{ section.settings.subheader_font_size_mobile | default: 16 }}px;
      line-height: 22px;
      max-width: {{ section.settings.subheader_max_width_mobile | default: 320 }}px;
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-badge .iwto-badge__img {
      max-width: {{ section.settings.badge_max_width_desktop | default: 280 }}px;
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-badge .iwto-badge__img {
      max-width: {{ section.settings.badge_max_width_mobile | default: 200 }}px;
    }
  }
  {% if section.settings.header_color != blank %}
    #shopify-section-{{ section.id }}
    .iwto-heading {
      color: {{ section.settings.header_color }};
    }
  {% endif %}
  {% if section.settings.subheader_color != blank %}
    #shopify-section-{{ section.id }}
    .iwto-subheader {
      color: {{ section.settings.subheader_color }};
    }
  {% endif %}
  {% if section.settings.body_text_color != blank %}
    #shopify-section-{{ section.id }}
    .iwto-body {
      color: {{ section.settings.body_text_color }};
    }
    #shopify-section-{{ section.id }}
    .iwto-body p {
      color: inherit;
    }
  {% endif %}
  {% if section.settings.button_bg_color != blank %}
    #shopify-section-{{ section.id }} [data-color-scheme] {
      --color-button-background: {{ section.settings.button_bg_color.red }}, {{ section.settings.button_bg_color.green }}, {{ section.settings.button_bg_color.blue }};
    }
  {% endif %}
  {% if section.settings.button_text_color != blank %}
    #shopify-section-{{ section.id }} [data-color-scheme] {
      --color-button-text: {{ section.settings.button_text_color.red }}, {{ section.settings.button_text_color.green }}, {{ section.settings.button_text_color.blue }};
    }
  {% endif %}
  {% if section.settings.button_outline_color != blank %}
    #shopify-section-{{ section.id }} [data-color-scheme] {
      --color-button-border: {{ section.settings.button_outline_color.red }}, {{ section.settings.button_outline_color.green }}, {{ section.settings.button_outline_color.blue }};
    }
  {% endif %}
  {% if section.settings.button_hover_bg_color != blank %}
    #shopify-section-{{ section.id }} [data-color-scheme] {
      --color-button-background-hover: {{ section.settings.button_hover_bg_color.red }}, {{ section.settings.button_hover_bg_color.green }}, {{ section.settings.button_hover_bg_color.blue }};
    }
  {% endif %}
  {% if section.settings.button_hover_text_color != blank %}
    #shopify-section-{{ section.id }} [data-color-scheme] {
      --color-button-text-hover: {{ section.settings.button_hover_text_color.red }}, {{ section.settings.button_hover_text_color.green }}, {{ section.settings.button_hover_text_color.blue }};
    }
  {% endif %}

  #shopify-section-{{ section.id }}
  .iwto-cta-wrap .push-btn__surface {
    font-size: 12px;
    font-weight: 600;
    padding: 12px 24px 9px;
    font-family: 'Founders Grotesk';
    text-transform: capitalize;
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-cta-wrap .push-btn__surface {
      font-size: 14px;
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-cta-wrap {
      margin-top: 0.2rem;
    }
    #shopify-section-{{ section.id }} .iwto-content-wrapper {
      padding-top: {{ section.settings.content_padding_mobile | default: 20 }}px;
      padding-bottom: {{ section.settings.content_padding_mobile | default: 20 }}px;
    }
    {% assign text_align_mobile = section.settings.text_align_mobile | default: 'default' %}
    {% unless text_align_mobile == 'default' %}
      {% case text_align_mobile %}
        {% when 'text-left' %}
          #shopify-section-{{ section.id }} .iwto-content-wrapper { text-align: left; }
        {% when 'text-center' %}
          #shopify-section-{{ section.id }} .iwto-content-wrapper { text-align: center; }
        {% when 'text-right' %}
          #shopify-section-{{ section.id }} .iwto-content-wrapper { text-align: right; }
      {% endcase %}
    {% endunless %}
  } 
  {% comment %} Only override max-width when 50vw or 75vw is chosen;
  otherwise Tailwind max-w-lg/max-w-xl(from snippet) applies. {% endcomment %}
{% assign text_max = section.settings.text_max_width_desktop | default: 'default' %}
{% if text_max == '32vw' or text_max == '50vw' or text_max == '75vw' %}
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .iwto-text-block {
      max-width: {{ text_max }};
      min-width: 22rem;
    }
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .iwto-text-block {
      max-width: 90vw;
      width: 90vw;
    }
  }
{% endif %}
  {% comment %} Tablet follows mobile: full centered text box up to 1024px (desktop overlay + position only from 1025px). {% endcomment %}
  @media (min-width: 990px) and (max-width: 1024px) {
    #shopify-section-{{ section.id }} .iwto-content-wrapper {
      position: static;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: auto;
    }
    #shopify-section-{{ section.id }} .iwto-content-wrapper .iwto-mobile-block {
      display: block;
    }
    #shopify-section-{{ section.id }} .iwto-content-wrapper .iwto-desktop-block {
      display: none;
    }
  }
</style>
{% comment %} End custom styles  {% endcomment %}

<section id="shopify-section-{{ section.id }}" class="{{ section.settings.custom__class }} image-with-text-overlay {% if page.template_suffix == 'index' %} main-home-banner {% endif %}  overflow-hidden bg-scheme-background text-scheme-text {% unless style == 'inset' %}full-bleed-section{% endunless %}  {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}" data-color-scheme="{{ section.settings.color_scheme }}">
  {%- liquid
    assign loading = 'lazy'
    if section.index <= 3
      assign loading = 'eager'
    endif

    assign preload = false
    if section.index == 1
      assign preload = true
    endif
  -%}

  <div class="section-content  {% if style == 'inset' %}py-section-vertical-spacing{% endif %}">
    {% render 'image-with-text-overlay'
      , image: section.settings.image
      , image_mobile: section.settings.image_mobile
      , place_content: section.settings.place_content
      , text_align: section.settings.text_align
      , color_scheme: section.settings.color_scheme
      , use_gradient_background: section.settings.use_gradient_background
      , subheader: section.settings.subheader
      , badge_image: section.settings.badge_image
      , title: section.settings.title
      , title_new_line_after_each_word: section.settings.title_new_line_after_each_word
      , richtext: section.settings.richtext
      , cta_url: section.settings.cta_url
      , cta_text: section.settings.cta_text
      , display_on_card: section.settings.display_on_card
      , style: style
      , mobile_style: mobile_style
      , crop: crop
      , slideshow_height: height
      , display_content_below_image_on_mobile: section.settings.display_content_below_image_on_mobile
      , heading_size: 'heading-standard'
      , loading: loading
      , preload: preload
    %}
  </div>

</section>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  assign no_padding = true
  if style == 'inset'
    assign no_padding = false
  endif
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider, no_padding: no_padding
  endfor
-%}

{% schema %}
  {
    "name": "t:sections.image_with_text_overlay.name",
    "class": "banner-section",
    "settings": [
      {
        "type": "text",
        "id": "custom__class",
        "label": "Additional Class"
      },
      {
        "id": "image",
        "type": "image_picker",
