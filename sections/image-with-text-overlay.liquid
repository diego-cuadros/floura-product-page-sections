        "id": "mobile_style",
        "label": "Mobile style",
        "default": "full",
        "options": [
          {
            "value": "inset",
            "label": "t:common.options.inset.label"
          }, {
            "value": "full",
            "label": "t:common.options.full_width.label"
          }
        ]
      }, {
        "type": "select",
        "id": "height",
        "label": "t:sections.image_with_text_overlay.settings.height.label",
        "options": [
