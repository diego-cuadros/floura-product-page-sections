        "label": "Subheader font size (desktop)",
        "default": 20
      }, {
        "type": "range",
        "id": "subheader_font_size_mobile",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Subheader font size (mobile)",
        "default": 16
      }, {
        "type": "color",
        "id": "subheader_color",
        "label": "Subheader color",
        "info": "Leave blank for theme default"
      }, {
        "type": "range",
        "id": "subheader_max_width_desktop",
        "min": 120,
        "max": 800,
        "step": 10,
        "unit": "px",
        "label": "Subheader max width (desktop)",
        "default": 500
      }, {
        "type": "range",
        "id": "subheader_max_width_mobile",
        "min": 120,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Subheader max width (mobile)",
        "default": 320
      }, {
        "type": "image_picker",
        "id": "badge_image",
        "label": "Badge above header",
        "info": "Image shown centered above the main heading (e.g. \"it's finally here!\")."
      }, {
        "type": "range",
        "id": "badge_max_width_desktop",
        "min": 60,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Badge max width (desktop)",
        "default": 280
      }, {
        "type": "range",
        "id": "badge_max_width_mobile",
        "min": 60,
        "max": 360,
        "step": 10,
