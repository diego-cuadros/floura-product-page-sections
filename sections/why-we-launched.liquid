

<style>

@media(max-width: 768px) {
  .wwl-block {
    flex-direction: column;
    text-align: center;
  }
  .wwl-block.reverse {
    flex-direction: column;
  }
  .wwl-block .wwl-img,
  .wwl-block .wwl-text {
    flex: 1 1 100%;
    max-width: 100%;
  }
  .wwl-block .wwl-svg {
    position: relative;
    right: auto;
    top: auto;
    margin: 0 auto 20px;
  }
}
</style>

<section class="why-we-launched">
  <h2>{{ section.settings.heading }}</h2>

  {% for block in section.blocks %}
    {% if block.settings.image %}
    {% assign layout_class = block.settings.reverse_layout | default: false %}
    <div class="wwl-block{% if layout_class %} reverse{% endif %} wwl-{{ forloop.index }}">
    <div class="wwl-block-inner">
        <div class="wwl-img">
          <img src="{{ block.settings.image | image_url: width: 800 }}" loading="lazy" alt="" />
        </div>

      <div class="wwl-text">
        <h3>{{ block.settings.head }}</h3>
        {{ block.settings.text | newline_to_br }}
      </div>
      </div>

      {% if block.settings.decorative_svg %}
        <div class="wwl-svg">
          <img src="{{ block.settings.decorative_svg | image_url: width: 200 }}" loading="lazy" alt="" />
        </div>
      {% endif %}
    </div>
  {% endif %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "Why We Launched",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why We Launched"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Content Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "head",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Content"
        },
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "Reverse Layout (Image Right)",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "decorative_svg",
          "label": "Optional Decorative SVG"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why We Launched",
      "blocks": [
        { "type": "block" },
        { "type": "block" },
        { "type": "block" }
      ]
    }
  ]
}
{% endschema %}