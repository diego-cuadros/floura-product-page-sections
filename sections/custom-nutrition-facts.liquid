{% schema %}
{
  "name": "Custom What's Inside",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Nutrition image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Inside"
    },
    {
      "type": "text",
      "id": "flavor",
      "label": "Flavor",
      "default": "Blueberry Matcha"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FBF5E1"
    },
    {
      "type": "color",
      "id": "flavor_text_color",
      "label": "Flavor text color",
      "default": "#414180"
    }
  ],
  "presets": [
    {
      "name": "Custom What's Inside"
    }
  ]
}
{% endschema %}
