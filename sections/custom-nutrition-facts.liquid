<style>
  /* Block */
  .nutrition-facts {
    width: 100%;
  }

  /* Layout — desktop and mobile trees swap at 749px */
  .nutrition-facts__layout {
    max-width: 1500px;
    margin: 0 auto;
    padding: 80px 8px;
  }
  .nutrition-facts__layout--desktop {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .nutrition-facts__layout--mobile {
    display: none;
  }

  .nutrition-facts__heading {
    font-size: 50px;
    font-weight: 500;
    font-family: 'Founders Grotesk', sans-serif;
    line-height: 1;
  }

  @media only screen and (max-width: 769px) {
    .nutrition-facts__heading {
      font-size: 35px;
      text-align: center;
    }
  }
  .nutrition-facts__flavor {
    font-size: 30px;
    font-weight: 500;
    font-family: 'Founders Grotesk', sans-serif;
  }

  @media only screen and (max-width: 769px) {
    .nutrition-facts__flavor {
      font-size: 25px;
      text-align: center;
    }
  }

  /* Columns */
  .nutrition-facts__columns {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 40px;
  }
  .nutrition-facts__column {
    width: 100%;
  }
  .nutrition-facts__column--left {
    max-width: 236px;
  }
  .nutrition-facts__column--center {
    margin-top: 2%;
    max-width: 500px;
  }
  .nutrition-facts__column--right {
    margin-top: 4%;
    max-width: 350px;
  }

  /* Product image */
  .nutrition-facts__image {
    width: 100%;
    max-width: 100%;
  }

  @media only screen and (max-width: 749px) {
    .nutrition-facts__image-wrapper {
      /* Post-rotation visual width of the image (its CSS height) */
      --rotated-image-width: min(70vw, 320px);
      display: flex;
      justify-content: center;
      align-items: center;
      /* Image is 222x498; rotated, its visual height = visual width * 222/498.
         Match the wrapper height so there's no gap/overflow around the image. */
      height: calc(var(--rotated-image-width) * 222 / 498);
    }
    .nutrition-facts__image {
      width: auto;
      height: var(--rotated-image-width);
      max-width: none;
      max-height: none;
      transform-origin: center center;
      transform: rotate(90deg);
    }
  }

  /* Feature highlights */
  .nutrition-facts__features {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    width: 100%;
    max-width: 750px;
  }
  .nutrition-facts__feature-icon {
    display: block;
    width: 76px;
    height: 76px;
    margin-bottom: 16px;
    border-radius: 100%;
    background-color: #e0e0e0;
    object-fit: cover;
  }

  @media only screen and (max-width: 749px) {
    .nutrition-facts__layout {
      padding: 16px;
    }
    .nutrition-facts__layout--desktop {
      display: none;
    }
    .nutrition-facts__layout--mobile {
      display: block;
    }
    .nutrition-facts__columns--mobile-row {
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 12px;
      margin-top: 24px;
    }
    .nutrition-facts__columns--mobile-row .nutrition-facts__column--mobile {
      flex: 1 1 0;
      min-width: 0;
    }
  }

  .nutrition-facts__stats {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .nutrition-facts__stat {
    background-color: #ffffff;
    border: 1px solid #000000;
    border-radius: 3px;
    padding: 16px 8px;
    display: flex;
    flex-direction: row;
    gap: 5px;
  }

  .nutrition-facts__stat-col {
    width: 100%;
    font-size: 12px;
  }

  .nutrition-facts__stat-col--left {
    text-align: left;
  }
  .nutrition-facts__stat-col--right {
    text-align: right;
  }
  .nutrition-facts__stat-col--right-down {
  }

  .nutrition-facts__stat-col--right-calories {
    font-size: 28px;
    font-weight: 500;
    margin: auto 0 auto auto;
  }

  .nutrition-facts__ingredients {
    margin-top: 25px;
  }

  .nutrition-facts__ingredients-label {
    font-weight: 500;
    font-size: 15px;
  }

  .nutrition-facts__ingredients-text {
    font-size: 12px;
  }

  .nutrition-facts__daily-value-label,
  .nutrition-facts__daily-value-label--bottom {
    font-size: 12px;
    font-family: 'Founders Grotesk', sans-serif;
    font-weight: 500;
    text-align: right;
  }

  .nutrition-facts__daily-value-label--bottom {
    font-size: 10px;
    text-align: left;
    margin-top: 10px;
  }

  .nutrition-facts__feature-name {
    text-align: center;
  }

  @media only screen and (max-width: 749px) {
    .nutrition-facts__feature-name {
      font-size: 8px;
    }

    .nutrition-facts__feature-icon {
      width: 40px;
      height: 40px;
    }
    .nutrition-facts__stat {
      padding: 6px;
    }
    .nutrition-facts__stat-col {
      font-size: 8px;
    }
    .nutrition-facts__stat-col--right-calories {
      font-size: 19px;
    }
    .nutrition-facts__ingredients-label {
      font-size: 12px;
    }
    .nutrition-facts__ingredients-text {
      font-size: 10px;
    }
    .nutrition-facts__daily-value-label {
      margin-top: -11px;
    }
    .nutrition-facts__daily-value-label,
    .nutrition-facts__daily-value-label--bottom {
      font-size: 8px;
    }
    .nutrition-facts__ingredients {
      padding-left: 8px;
    }
  }
</style>

{%- liquid
  # Pull heading/flavor from the variant metaobject metafield when present,
  # otherwise fall back to the section settings.
  # NOTE: `.title` and `.flavor` below are the metaobject FIELD KEYS (API handles).
  # If your metaobject uses different keys, change them here.
  assign values_for_heading = section.settings.heading
  assign values_for_flavor = section.settings.flavor
  assign values_for_bar_image = section.settings.image_picker

  # comment
  # assign values_for_first_block_properties = blank
  # assign values_for_ingredients_text = blank
  # assign values_for_daily_value_note = blank

  assign metaobject = product.selected_or_first_available_variant.metafields.custom.nutrition_facts_bottomless.value
  if metaobject != blank
    if metaobject.bar_image != blank
      assign values_for_bar_image = metaobject.bar_image
    endif
    if metaobject.title != blank
      assign values_for_heading = metaobject.title
    endif
    if metaobject.flavor != blank
      assign values_for_flavor = metaobject.flavor
    endif

    if metaobject.first_block_properties != blank
      assign values_for_first_block_properties = metaobject.first_block_properties | metafield_tag
    endif
    if metaobject.first_block_values != blank
      assign values_for_first_block_values = metaobject.first_block_values | metafield_tag
    endif

    if metaobject.second_block_properties != blank
      assign values_for_second_block_properties = metaobject.second_block_properties | metafield_tag
    endif
    if metaobject.second_block_values != blank
      assign values_for_second_block_values = metaobject.second_block_values | metafield_tag
    endif

    if metaobject.third_block_properties != blank
      assign values_for_third_block_properties = metaobject.third_block_properties | metafield_tag
    endif
    if metaobject.third_block_values != blank
      assign values_for_third_block_values = metaobject.third_block_values | metafield_tag
    endif

    if metaobject.fourth_block_properties != blank
      assign values_for_fourth_block_properties = metaobject.fourth_block_properties | metafield_tag
    endif
    if metaobject.fourth_block_values != blank
      assign values_for_fourth_block_values = metaobject.fourth_block_values | metafield_tag
    endif

    if metaobject.fifth_block_properties != blank
      assign values_for_fifth_block_properties = metaobject.fifth_block_properties | metafield_tag
    endif
    if metaobject.fifth_block_values != blank
      assign values_for_fifth_block_values = metaobject.fifth_block_values | metafield_tag
    endif

    if metaobject.sixth_block_properties != blank
      assign values_for_sixth_block_properties = metaobject.sixth_block_properties | metafield_tag
    endif
    if metaobject.sixth_block_values != blank
      assign values_for_sixth_block_values = metaobject.sixth_block_values | metafield_tag
    endif

    if metaobject.seventh_block_properties != blank
      assign values_for_seventh_block_properties = metaobject.seventh_block_properties | metafield_tag
    endif
    if metaobject.seventh_block_values != blank
      assign values_for_seventh_block_values = metaobject.seventh_block_values | metafield_tag
    endif

    if metaobject.eighth_block_properties != blank
      assign values_for_eighth_block_properties = metaobject.eighth_block_properties | metafield_tag
    endif
    if metaobject.eighth_block_values != blank
      assign values_for_eighth_block_values = metaobject.eighth_block_values | metafield_tag
    endif

    if metaobject.ingredients_text != blank
      assign values_for_ingredients_text = metaobject.ingredients_text | metafield_tag
    endif
    if metaobject.daily_value_note != blank
      assign values_for_daily_value_note = metaobject.daily_value_note | metafield_tag
    endif
  endif
-%}

<section
  class="nutrition-facts"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  {%- comment -%} Desktop layout {%- endcomment -%}
  <div class="nutrition-facts__layout nutrition-facts__layout--desktop">
    <div class="nutrition-facts__columns">
      <div class="nutrition-facts__column nutrition-facts__column--left">
        {%- if values_for_bar_image != blank -%}
          {{
            values_for_bar_image
            | image_url: width: 600
            | image_tag: class: 'nutrition-facts__image', alt: values_for_bar_image.alt
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'nutrition-facts__image placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="nutrition-facts__column nutrition-facts__column--center">
        <div class="nutrition-facts__title">
          <h2 class="nutrition-facts__heading">{{ values_for_heading }}</h2>
          <h3
            class="nutrition-facts__flavor"
            {% if section.settings.flavor_text_color != blank %}
              style="color: {{ section.settings.flavor_text_color }};"
            {% endif %}
          >
            {{ values_for_flavor }}
          </h3>
        </div>
        <div class="nutrition-facts__stats">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'center_stat' -%}
                <div class="nutrition-facts__stat" {{ block.shopify_attributes }}>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--left">
                    {% if forloop.index == 1 %}
                      {{ values_for_first_block_properties | default: block.settings.left }}
                    {% else %}
                      {{ block.settings.left }}
                    {% endif %}
                  </div>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--right nutrition-facts__stat-col--right-down">
                    {% if forloop.index == 1 %}
                      {{ values_for_first_block_values | default: block.settings.right }}
                    {% else %}
                      {{ block.settings.right }}
                    {% endif %}
                  </div>
                </div>
              {%- when 'center_stat_calories' -%}
                <div class="nutrition-facts__stat" {{ block.shopify_attributes }}>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--left">
                    {% if forloop.index == 2 %}
                      {{ values_for_second_block_properties | default: block.settings.left }}
                    {% else %}
                      {{ block.settings.left }}
                    {% endif %}
                  </div>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--right nutrition-facts__stat-col--right-calories">
                    {% if forloop.index == 2 %}
                      {{ values_for_second_block_values | default: block.settings.left }}
                    {% else %}
                      {{ block.settings.right }}
                    {% endif %}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'ingredients' -%}
            <div class="nutrition-facts__ingredients" {{ block.shopify_attributes }}>
              <h4 class="nutrition-facts__ingredients-label">{{ block.settings.label }}</h4>
              <div class="nutrition-facts__ingredients-text">
                {{ values_for_ingredients_text | default: block.settings.text }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="nutrition-facts__column nutrition-facts__column--right">
        <p class="nutrition-facts__daily-value-label">{{ section.settings.daily_value_label }}</p>
        <div class="nutrition-facts__stats">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'right_stat' -%}
                <div class="nutrition-facts__stat" {{ block.shopify_attributes }}>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--left">
                    {% if forloop.index == 4 %}
                      {{ values_for_third_block_properties | default: block.settings.left }}
                    {% elsif forloop.index == 5 %}
                      {{ values_for_fourth_block_properties | default: block.settings.left }}
                    {% elsif forloop.index == 6 %}
                      {{ values_for_fifth_block_properties | default: block.settings.left }}
                    {% elsif forloop.index == 7 %}
                      {{ values_for_sixth_block_properties | default: block.settings.left }}
                    {% elsif forloop.index == 8 %}
                      {{ values_for_seventh_block_properties | default: block.settings.left }}
                    {% elsif forloop.index == 9 %}
                      {{ values_for_eighth_block_properties | default: block.settings.left }}
                    {% else %}
                      {{ block.settings.left }}
                    {% endif %}
                  </div>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--right nutrition-facts__stat-col--right-down">
                    {% if forloop.index == 4 %}
                      {{ values_for_third_block_values | default: block.settings.right }}
                    {% elsif forloop.index == 5 %}
                      {{ values_for_fourth_block_values | default: block.settings.right }}
                    {% elsif forloop.index == 6 %}
                      {{ values_for_fifth_block_values | default: block.settings.right }}
                    {% elsif forloop.index == 7 %}
                      {{ values_for_sixth_block_values | default: block.settings.right }}
                    {% elsif forloop.index == 8 %}
                      {{ values_for_seventh_block_values | default: block.settings.right }}
                    {% elsif forloop.index == 9 %}
                      {{ values_for_eighth_block_values | default: block.settings.right }}
                    {% else %}
                      {{ block.settings.right }}
                    {% endif %}
                  </div>
                </div>
              {%- when 'right_stat_calories' -%}
                <div class="nutrition-facts__stat" {{ block.shopify_attributes }}>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--left">
                    {{ block.settings.left }}
                  </div>
                  <div class="nutrition-facts__stat-col nutrition-facts__stat-col--right nutrition-facts__stat-col--right-calories">
                    {{ block.settings.right }}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'daily_value_note' -%}
            <div class="nutrition-facts__daily-value-label--bottom" {{ block.shopify_attributes }}>
              {{ values_for_daily_value_note | default: block.settings.text }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="nutrition-facts__features">
      {%- assign feature_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          {%- assign feature_index = feature_index | plus: 1 -%}
          {%- assign feature_key = 'image_feature_' | append: feature_index -%}
          {%- assign feature_label_key = 'feature_' | append: feature_index -%}
          {%- assign feature_icon = block.settings.icon -%}
          {%- assign feature_label = block.settings.name -%}
          {%- if metaobject != blank and metaobject[feature_key] != blank -%}
            {%- assign feature_icon = metaobject[feature_key] -%}
          {%- endif -%}
          {%- if metaobject != blank and metaobject[feature_label_key] != blank -%}
            {%- assign feature_label = metaobject[feature_label_key] -%}
          {%- endif -%}
          <div class="nutrition-facts__feature" {{ block.shopify_attributes }}>
            {%- if feature_icon != blank -%}
              {{
                feature_icon
                | image_url: width: 152
                | image_tag: class: 'nutrition-facts__feature-icon', alt: feature_label
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'nutrition-facts__feature-icon placeholder-svg' }}
            {%- endif -%}
            <h3 class="nutrition-facts__feature-name">{{ feature_label }}</h3>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

