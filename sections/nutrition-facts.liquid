<section class="nutrition-facts-section">
  <h2 class="inline-heading-rte font-heading heading-standard  heading-style break-words text-center none">{{ section.settings.head }}</h2>
  <div class="nutrition-wrapper">
    <div class="nutrition-left">
      <div class="ingredient-list">
        <strong>Ingredient list:</strong><br>
        <p>{{ section.settings.ingredient_list | newline_to_br }}</p>
      </div>
      <div class="serving-info">
        <div>1 Serving Per Container</div>
        <div><strong>Serving Size</strong> 1 Bar (45g)</div>
      </div>
      {% comment %} <div class="calories-box">
        <div>Amount Per Serving</div>
        <div class="calories-box-inner">
        <div><strong>Calories</strong></div>
        <div class="calories-number">{{ section.settings.calories }}</div>
        </div>
      </div> {% endcomment %}
    </div>

    <div class="nutrition-center">
      {% if section.settings.bar_image %}
        <img src="{{ section.settings.bar_image | image_url: width: 600 }}" alt="Bar Image" class="bar-image" loading="lazy">
      {% endif %}
    </div>

    <div class="nutrition-right">
      {% for block in section.blocks %}
        <div class="fact-box">
          <div class="fact-title">{{ block.settings.title }}</div>
          <div class="fact-value">{{ block.settings.value }}</div>
          {% if block.settings.note != blank %}
            <div class="fact-note">{{ block.settings.note }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  <p class="btmln">{{ section.settings.btmln }}</p>
</section>

{% schema %}
{
  "name": "Nutrition Facts",
  "settings": [
    {
      "type": "text",
      "id": "head",
      "label": "Main Heading"
    },
    {
      "type": "image_picker",
      "id": "bar_image",
      "label": "Bar Image"
    },
    {
      "type": "richtext",
      "id": "ingredient_list",
      "label": "Ingredient List"
    },
    {
      "type": "text",
      "id": "calories",
      "label": "Calories",
      "default": "140"
    },
     {
      "type": "text",
      "id": "btmln",
      "label": "Bottom Line"
    },
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Nutrition Fact",
      "settings": [
        {
          "type": "liquid",
          "id": "title",
          "label": "Box Content"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Nutrition Facts",
      "blocks": [
        { "type": "fact" }
      ]
    }
  ]
}
{% endschema %}