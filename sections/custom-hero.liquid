<style>
    .custom-hero {
      width: 100%;
    }
    .custom-hero__pattern {
      width: 100%;
      background-repeat: repeat-x;
      background-position: center bottom;
      background-size: auto 100%;
    }
    .custom-hero__layout {
      align-items: center;
      display: flex;
      flex-direction: row;
      justify-content: center;
      max-width: 1500px;
      margin: 0 auto;
      padding: 80px 8px;
    }
    .text-on-left {
      text-align: left;
    }
    .text-on-center {
      text-align: center;
    }
    .text-on-right {
      text-align: right;
    }

  {%- if section.settings.image != blank -%}
    .custom-hero__written-content {
      flex: 0 0 50%;
      max-width: 50%;
    }
  {% else %}
    .custom-hero__written-content {
      flex: 0 0 100%;
      max-width: 100%;
    }
  {% endif %}

    .custom-hero__written-title {
      font-size: 50px;
      font-weight: 500;
      font-family: 'Founders Grotesk', sans-serif;
    }
    @media only screen and (max-width: 749px) {
      .custom-hero__written-title {
        font-size: 35px;
      }
    }

    .custom-hero__written-text {
      font-weight: 400;
      font-size: 30px;
      font-family: 'Founders Grotesk', sans-serif;
      line-height: 35px;
    }
    @media only screen and (max-width: 749px) {
      .custom-hero__written-text {
        font-size: 15px;
        line-height: 18px;
      }
    }

    .custom-hero__image {
      flex: 0 0 50%;
      max-width: 50%;
      display: flex;
      justify-content: center;
    }

    .custom-hero__image img {
      aspect-ratio: 1 / 1;
      width: 364px;
      height: auto;
      object-fit: cover;
      border-radius: 50%;
    }

    #custom-hero-{{ section.id }} .custom-hero__written-text {
      font-size: {{ section.settings.text_font_size_desktop }}px;
      line-height: {{ section.settings.text_line_height_desktop }}px;
    }
    @media only screen and (max-width: 749px) {
      #custom-hero-{{ section.id }} .custom-hero__written-text {
        font-size: {{ section.settings.text_font_size_mobile }}px;
        line-height: {{ section.settings.text_line_height_mobile }}px;
      }
    }

    #custom-hero-{{ section.id }} .custom-hero__pattern {
      height: {{ section.settings.pattern_height }}px;
    }
    @media only screen and (max-width: 749px) {
      #custom-hero-{{ section.id }} .custom-hero__pattern {
        height: {{ section.settings.pattern_height_mobile }}px;
      }
    }
</style>

{%- comment -%}
  Variant-aware custom hero.
  Every variant's content is pre-rendered (keyed by data-variant-id) and all but the
  current one are hidden. A small delegated script (bottom of the section) swaps which
  one is visible when the shopper picks a different variant — no page reload. Variant
  selection is detected via:
    - bundle-subscription buy box: [data-variant-radio] / [data-variant-id]
      (that template dispatches NO theme:variant:change — see snippets/buy-box-bundle-subscription.liquid)
    - standard product templates: theme:variant:change / shapes:product:variantchange events
    - URL ?variant=ID on load
{%- endcomment -%}

{%- liquid
  assign ch_current_variant = product.selected_or_first_available_variant
  assign ch_wrapper_id = 'custom-hero-' | append: section.id
  # Variant id for which this whole section must be hidden (e.g. variety pack).
  assign ch_hidden_variant_id = 52270001881410
-%}

<section
  class="custom-hero"
  id="{{ ch_wrapper_id }}"
  data-ch-hidden-variant-id="{{ ch_hidden_variant_id }}"
  style="{%- if ch_current_variant.id == ch_hidden_variant_id %}display: none;{% endif -%}"
>
  {%- for variant in product.variants -%}
    {%- liquid
      # Pull hero styling/content from the variant's metaobject metafield when present,
      # otherwise fall back to the section settings.
      # NOTE: the keys below (`background_color`, `title_text_color`, `text_color`,
      # `bold_text_color`, `pattern_image`, `text`) are the metaobject FIELD KEYS (API handles)
      # on the "beyond the flavor" metaobject. If your metaobject uses different keys, change them here.
      assign values_for_background_color = section.settings.background_color
      assign values_for_title_color = section.settings.title_color
      assign values_for_text_color = section.settings.text_color
      assign values_for_bold_text_color = section.settings.bold_text_color
      assign values_for_pattern_image = section.settings.pattern_image
      assign values_for_text = section.settings.text

      assign ch_metaobject = variant.metafields.custom.beyond_the_flavor_config.value
      if ch_metaobject != blank
        if ch_metaobject.background_color != blank
          assign values_for_background_color = ch_metaobject.background_color
        endif
        if ch_metaobject.title_text_color != blank
          assign values_for_title_color = ch_metaobject.title_text_color
        endif
        if ch_metaobject.text_color != blank
          assign values_for_text_color = ch_metaobject.text_color
        endif
        if ch_metaobject.bold_text_color != blank
          assign values_for_bold_text_color = ch_metaobject.bold_text_color
        endif
        if ch_metaobject.pattern_image != blank
          assign values_for_pattern_image = ch_metaobject.pattern_image
        endif
        if ch_metaobject.text != blank
          assign values_for_text = ch_metaobject.text | metafield_tag
        endif
      endif
    -%}
    <div
      class="custom-hero__variant"
      data-variant-id="{{ variant.id }}"
      style="background-color: {{ values_for_background_color }};{% unless variant.id == ch_current_variant.id %}display: none;{% endunless %}"
    >
      <style>
        #{{ ch_wrapper_id }} [data-variant-id="{{ variant.id }}"] .custom-hero__written-text strong,
        #{{ ch_wrapper_id }} [data-variant-id="{{ variant.id }}"] .custom-hero__written-text b {
          color: {{ values_for_bold_text_color }};
        }
      </style>

      <div class="custom-hero__layout">
        <div class="custom-hero__written-content text-on-{{ section.settings.text_alignment }}">
          {%- if section.settings.title != blank -%}
            <h2 class="custom-hero__written-title" style="color: {{ values_for_title_color }};">
              {{ section.settings.title }}
            </h2>
          {%- endif -%}
          {%- if values_for_text != blank -%}
            <div class="custom-hero__written-text" style="color: {{ values_for_text_color }};">
              {{ values_for_text }}
            </div>
          {%- endif -%}
        </div>
        {%- if section.settings.image != blank -%}
          <div class="custom-hero__image">
            <img
              src="{{ section.settings.image | image_url: width: 1500 }}"
              alt="{{ section.settings.image.alt | escape }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
            >
          </div>
        {%- endif -%}
      </div>

      {%- if values_for_pattern_image != blank -%}
        <div
          class="custom-hero__pattern"
          style="background-image: url({{ values_for_pattern_image | image_url: width: 1500 }});"
          role="presentation"
        ></div>
      {%- endif -%}
    </div>
  {%- endfor -%}

  <script>
    (function () {
      var wrapper = document.getElementById('{{ ch_wrapper_id }}');
      if (!wrapper || wrapper.dataset.chBound) return;
      wrapper.dataset.chBound = '1';

      var hiddenVariantId = wrapper.dataset.chHiddenVariantId || '';

      function showVariant(variantId) {
        if (!variantId) return;
        var target = String(variantId);

        // Hide the entire section for the configured variant.
        if (hiddenVariantId && target === hiddenVariantId) {
          wrapper.style.display = 'none';
          return;
        }
        wrapper.style.display = '';

        wrapper.querySelectorAll('.custom-hero__variant').forEach(function (slide) {
          slide.style.display = slide.dataset.variantId === target ? '' : 'none';
        });
      }

      // Standard product templates: Shapes product island events.
      function handleThemeEvent(event) {
        var variant = event.detail && event.detail.variant;
        if (variant && variant.id) showVariant(variant.id);
      }
      document.addEventListener('theme:variant:change', handleThemeEvent);
      document.addEventListener('shapes:product:variantchange', handleThemeEvent);

      // Bundle-subscription buy box (no variant-change event is dispatched).
      document.addEventListener('change', function (event) {
        var radio = event.target.closest && event.target.closest('[data-variant-radio]');
        if (radio) showVariant(radio.value);
      });
      document.addEventListener('click', function (event) {
        var el = event.target.closest && event.target.closest('[data-variant-id]');
        if (el) showVariant(el.dataset.variantId);
      });

      // Initial state: honour a pre-selected variant from the URL (?variant=ID).
      var requestedId = new URLSearchParams(window.location.search).get('variant');
      if (requestedId) showVariant(requestedId);
    })();
  </script>
</section>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Beyond the Flavor"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Blueberries and blue matcha contribute more than flavor and color. Both are naturally rich in anthocyanins – plant compounds that research suggests may help support overall health and wellbeing. That’s one reason they fit naturally into the Floura philosophy: real foods bring something more to the table.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FBF5E1"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#C5273C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bold_text_color",
      "label": "Bold text color",
      "default": "#C5273C"
    },
    {
      "type": "range",
      "id": "text_font_size_desktop",
      "label": "Text font size (desktop)",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "label": "Text font size (mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height_desktop",
      "label": "Text line height (desktop)",
      "min": 12,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "text_line_height_mobile",
      "label": "Text line height (mobile)",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "image_picker",
      "id": "pattern_image",
      "label": "Bottom pattern image",
      "info": "Decorative pattern that repeats horizontally across the full width."
    },
    {
      "type": "range",
      "id": "pattern_height",
      "label": "Pattern height",
      "min": 10,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}
