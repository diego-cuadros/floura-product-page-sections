{%- liquid
  # Pull hero styling/content from the current variant's metaobject metafield when present,
  # otherwise fall back to the section settings (same pattern as custom-nutrition-facts).
  # NOTE: the keys below (`background_color`, `title_text_color`, `text_color`,
  # `bold_text_color`, `pattern_image`, `text`) are the metaobject FIELD KEYS (API handles)
  # on the "beyond the flavor" metaobject. If your metaobject uses different keys, change them here.
  assign bf_current_variant = product.selected_or_first_available_variant

  assign values_for_background_color = section.settings.background_color
  assign values_for_title_color = section.settings.title_color
  assign values_for_text_color = section.settings.text_color
  assign values_for_bold_text_color = section.settings.bold_text_color
  assign values_for_pattern_image = section.settings.pattern_image
  assign values_for_text = section.settings.text

  assign bf_metaobject = bf_current_variant.metafields.custom.beyond_the_flavor_config.value
  if bf_metaobject != blank
    if bf_metaobject.background_color != blank
      assign values_for_background_color = bf_metaobject.background_color
    endif
    if bf_metaobject.title_text_color != blank
      assign values_for_title_color = bf_metaobject.title_text_color
    endif
    if bf_metaobject.text_color != blank
      assign values_for_text_color = bf_metaobject.text_color
    endif
    if bf_metaobject.bold_text_color != blank
      assign values_for_bold_text_color = bf_metaobject.bold_text_color
    endif
    if bf_metaobject.pattern_image != blank
      assign values_for_pattern_image = bf_metaobject.pattern_image
    endif
    if bf_metaobject.text != blank
      assign values_for_text = bf_metaobject.text | metafield_tag
    endif
  endif
-%}

<style>
    .custom-hero {
      width: 100%;
    }
    .custom-hero__pattern {
      width: 100%;
      background-repeat: repeat-x;
      background-position: center bottom;
      background-size: auto 100%;
    }
    .custom-hero__layout {
      align-items: center;
      display: flex;
      flex-direction: row;
      justify-content: center;
      max-width: 1500px;
      margin: 0 auto;
      padding: 80px 8px;
    }
    .text-on-left {
      text-align: left;
    }
    .text-on-center {
      text-align: center;
    }
    .text-on-right {
      text-align: right;
    }

  {%- if section.settings.image != blank -%}
    .custom-hero__written-content {
      flex: 0 0 50%;
      max-width: 50%;
    }
  {% else %}
    .custom-hero__written-content {
      flex: 0 0 100%;
      max-width: 100%;
    }
  {% endif %}

    .custom-hero__written-title {
      font-size: 50px;
      font-weight: 500;
      font-family: 'Founders Grotesk', sans-serif;
    }
    @media only screen and (max-width: 749px) {
      .custom-hero__written-title {
        font-size: 35px;
      }
    }

    .custom-hero__written-text {
      font-weight: 400;
      font-size: 30px;
      font-family: 'Founders Grotesk', sans-serif;
      line-height: 35px;
    }
    @media only screen and (max-width: 749px) {
      .custom-hero__written-text {
        font-size: 15px;
        line-height: 18px;
      }
    }

    .custom-hero__image {
      flex: 0 0 50%;
      max-width: 50%;
      display: flex;
      justify-content: center;
    }

    .custom-hero__image img {
      aspect-ratio: 1 / 1;
      width: 364px;
      height: auto;
      object-fit: cover;
      border-radius: 50%;
    }

    #custom-hero-{{ section.id }} .custom-hero__written-text strong,
    #custom-hero-{{ section.id }} .custom-hero__written-text b {
      color: {{ values_for_bold_text_color }};
    }

    #custom-hero-{{ section.id }} .custom-hero__written-text {
      font-size: {{ section.settings.text_font_size_desktop }}px;
      line-height: {{ section.settings.text_line_height_desktop }}px;
    }
    @media only screen and (max-width: 749px) {
      #custom-hero-{{ section.id }} .custom-hero__written-text {
        font-size: {{ section.settings.text_font_size_mobile }}px;
        line-height: {{ section.settings.text_line_height_mobile }}px;
      }
    }

    #custom-hero-{{ section.id }} .custom-hero__pattern {
      height: {{ section.settings.pattern_height }}px;
    }
    @media only screen and (max-width: 749px) {
      #custom-hero-{{ section.id }} .custom-hero__pattern {
        height: {{ section.settings.pattern_height_mobile }}px;
      }
    }
</style>
<section
  class="custom-hero"
  id="custom-hero-{{ section.id }}"
  style="background-color: {{ values_for_background_color }};"
>
  <div class="custom-hero__layout">
    <div class="custom-hero__written-content text-on-{{ section.settings.text_alignment }}">
      {%- if section.settings.title != blank -%}
        <h2 class="custom-hero__written-title" style="color: {{ values_for_title_color }};">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      {%- if values_for_text != blank -%}
        <div class="custom-hero__written-text" style="color: {{ values_for_text_color }};">
          {{ values_for_text }}
        </div>
      {%- endif -%}
    </div>
    {%- if section.settings.image != blank -%}
      <div class="custom-hero__image">
        <img
          src="{{ section.settings.image | image_url: width: 1500 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
      </div>
    {%- endif -%}
  </div>

  {%- if values_for_pattern_image != blank -%}
    <div
      class="custom-hero__pattern"
      style="background-image: url({{ values_for_pattern_image | image_url: width: 1500 }});"
      role="presentation"
    ></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Beyond the Flavor"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Blueberries and blue matcha contribute more than flavor and color. Both are naturally rich in anthocyanins – plant compounds that research suggests may help support overall health and wellbeing. That’s one reason they fit naturally into the Floura philosophy: real foods bring something more to the table.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FBF5E1"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#C5273C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bold_text_color",
      "label": "Bold text color",
      "default": "#C5273C"
    },
    {
      "type": "range",
      "id": "text_font_size_desktop",
      "label": "Text font size (desktop)",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "label": "Text font size (mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height_desktop",
      "label": "Text line height (desktop)",
      "min": 12,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "text_line_height_mobile",
      "label": "Text line height (mobile)",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "image_picker",
      "id": "pattern_image",
      "label": "Bottom pattern image",
      "info": "Decorative pattern that repeats horizontally across the full width."
    },
    {
      "type": "range",
      "id": "pattern_height",
      "label": "Pattern height",
      "min": 10,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}
