{{ 'hotspot.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{%- liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}
<div class="section-{{ section.id }}-padding gradient humans_outer_sec section-content  color-{{ section.settings.color_scheme }} hotspot-images--{{  section.settings.image_ratio }}">
  <div class="veda-container px-section">
    <div class="{% if section.settings.layout == 'grid' %} page-width {% else %}container-fluid{% endif %}">
      {% if section.settings.section_heading != blank or section.settings.section_description != blank %}
        <div class="time-line-flex content-alignment--{{ section.settings.content_alignment }}">
          <div class="bundle-info-title-des">
            {% if section.settings.section_heading != blank %}
              <h2>
                {{ section.settings.section_heading }}
              </h2>
            {% endif %}
            {% if section.settings.section_description != blank %}
              <div class="animate-element" data-animate="fade-up-large" data-animate-delay="50">
                {{ section.settings.section_description }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
      <div class="veda-hotspot-section-wrapper hotspot-container image-position-{{ section.settings.layout_image }} ">
        {% if section.settings.verticle_text != blank %}
          <div class="hotstop-left-side-side-stripe-text animate-on-scroll" >
            {{ section.settings.verticle_text | truncate: 8, '.' }}
          </div>
        {% endif %}
        <div class="hotstop-left-side">
         
          {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
            {%- endcapture -%}
          {% if section.settings.image != blank %}
            {{-
              section.settings.image
              | image_url: width: 1500
              | image_tag:
                sizes: sizes,
                widths: '2000',
                fetchpriority: fetch_priority,
                title: section.settings.image.alt
            -}}
          {% else %}
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}

          {% for block in section.blocks %}
            <div
              class="hotspot hotspot-icon-wrapper"
              id="hotspot{{ forloop.index }}"
              data-attr="{{ forloop.index }}"
              style="top: {{ block.settings.vertical_position }}%; left: {{ block.settings.horizontal_position }}%; transform: translate(-50%, -50%);"
            >
              <div class="hot-spot-bg"></div>
              {{ 'icon-hotspot.svg' | inline_asset_content }}
            </div>
          {% endfor %}
        </div>

        <div class="hotstop-right-side active">
          <div class="hotstop-right-side-inner">
            <div class="veda-hotstop-content-wrapper">
              {%- if section.settings.heading != blank -%}
                <h2 class="{{ section.settings.heading_style }} {{ section.settings.heading_size }} animate-element">
                  {{ section.settings.heading }}
                </h2>
              {%- endif -%}
              {% if section.settings.description != blank %}
                <div class="animate-element" data-animate="fade-up-large" data-animate-delay="50">
                {{ section.settings.description }}
                </div>
              {% endif %}
              {%- if section.settings.button_label != blank -%}
                <div class="hotpsot-section-button-label">
                  <a
                    {% if section.settings.open_link %}
                      target="_blank"
                    {% endif %}
                    {% if section.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ section.settings.button_link }}"
                    {% endif %}
                    class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                    {{ section.shopify_attributes }}
                  >
                    {{ section.settings.button_label | escape }}
                  </a>
                </div>
              {%- endif -%}
            </div>
            
            <div class="wnsm-hot-spot-slider animate-element" data-animate="fade-up-large" data-animate-delay="60">
              {% for block in section.blocks %}
                {% assign product = block.settings.product %}

                <div class="slider {% if forloop.index == 1 %}active{% endif %}" data-attr="{{ forloop.index }}">
                  <div class="hot-spot-content--wrapper color-{{ block.settings.color_scheme }}">
                    <div class="hot-spot-image--wrapper">
                      {% if product != blank %}
                        <a href="{{ product.url  }}">
                      {% endif %}
                      {% comment %} {% if product != blank %}
                        {{-
                          product.featured_image
                          | image_url: width: 300
                          | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority, title: product.title
                        -}}
                      {% else %}
                        {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %} {% endcomment %}
                       {% if block.settings.prodimg != balnk %}
                        {{-
                          block.settings.prodimg
                          | image_url: width: 600
                          | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority, title: product.title
                        -}}
                        {% elsif product != blank %}
                        {{-
                          product.featured_image
                          | image_url: width: 600
                          | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority, title: product.title
                        -}}
                      {% else %}
                        {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                      {% if product != blank %}
                        </a>
                      {% endif %}
                    </div>
                    <div class="product-information">
                      {% if product != blank %}
                        <a href="{{ product.url  }}">
                      {% endif %}
                      <div class="product--content">
                        {% if block.settings.tag_name != blank %}
                          <div
                            class="product-tag"
                            style="color:{{ block.settings.tag_color }}; background-color:{{ block.settings.tag_background_color }};"
                          >
                            {{ block.settings.tag_name }}
                          </div>
                        {% endif %}
                        <div class="product-title">
                          {% if product != blank -%}
                            {{- product.title -}}
                          {%- else -%}
                            {{- section.settings.heading }}
                            {{ forloop.index -}}
                          {%- endif %}
                        </div>
                        <div class="product-rating">
                           {% render 'product-block-star-rating',
                      product: product,
                      block: block
                    %}
                        </div>
                        {% if product != blank %}
                          <div class="product-price">
                            <span class="product-actual-price">
                              {{- product.selected_or_first_available_variant.price | money }}
                            </span>
                            {% if product.selected_or_first_available_variant.compare_at_price != blank %}
                              <span class="product-comapre-price">
                                {{- product.selected_or_first_available_variant.compare_at_price | money -}}
                              </span>
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if product != blank %}
                          <div class="product-description">
                          <div class="pdi">
                            <b>Flavor notes: </b>
                            <p class="pdifn">{{ product.metafields.custom.excerpt }}</p>
                            <b>Ingredient list: </b>
                            <p class="pdiil">{{ product.metafields.custom.ingredient | metafield_tag }}</p>
                          </div>
                          </div>
                        {% endif %}
                      </div>
                      {% if product != blank %}
                        </a>
                      {% endif %}
                      {%- assign product_form_id = 'product-form-' | append: section.id -%}

                      {%- assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: forloop.index -%}

                    <div class="button_outer flex"> 

                     <data-island
                        class="contents"
                        x-data="
                          QuickBuy({
                            product: {{ product | json | escape }},
                            variant: {{ product.selected_or_first_available_variant | json | escape }},
                            featuredMediaID: {{ product.selected_or_first_available_variant.featured_media.id | json }}
                          })
                        "
                        src="{{ 'island-quick-buy.bundle.js' | asset_url }}"
                        data-product-root="{{ section.id }}-{{ product.id }}"
                      >
                        <div class="hotspot-atc-btn">
                          {%- render 'product-tile-quick-buy',
                            section: section,
                            product: product,
                            product_form_id: product_form_id,
                            current_variant: product.selected_or_first_available_variant,
                            current_variant_only: product.has_only_default_variant
                          -%}
                        </div>
                      </data-island>


                      <a class="bundle-button" href="{{ section.settings.bbl }}">Build a Bundle</a></div>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
            <div class="dots-container">
              {% for block in section.blocks %}
                <span class="dot {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index }}"></span>
              {% endfor %}
            </div>
            <div class="share-block-main-product product-block-share-buttons">
            {% render 'share-icon-',
                  share_title: article.title,
                  share_permalink: article.url,
                  share_image: article.image
                %}
            </div> 
          </div>
           
        </div>
      </div>
    </div>
  </div>
</div>
<script src="{{ 'hotspot.js' | asset_url }}" defer="defer"></script>
{% schema %}
{
  "name": "t:sections.hotspot.name",
  "settings": [
         {
      "type": "inline_richtext",
      "id": "section_heading",
       "label": "t:sections.hotspot.settings.section_heading.label",
        "default": "t:sections.hotspot.settings.section_heading.default"
    },
       {
      "type": "richtext",
      "id": "section_description",
       "label": "t:sections.hotspot.settings.section_description.label",
        "default": "t:sections.hotspot.settings.section_description.default"
    },
    {
      "type": "url",
      "id": "bbl",
       "label": "Bundle Button Link"
    },
    {
      "type": "text",
      "id": "verticle_text",
       "label": "t:sections.hotspot.settings.verticle_text.label",
        "default": "t:sections.hotspot.settings.verticle_text.default",
      "info":"t:sections.hotspot.settings.verticle_text.info"
    },
    {
      "type": "image_picker",
          "id": "image",
          "label": "t:sections.hotspot.settings.image.label",
      "info": "t:sections.hotspot.settings.image.info"
        },
     {
      "type": "select",
      "id": "layout_image",
      "options": [
        {
          "value": "image_first",
          "label": "t:sections.hotspot.settings.imgae_layout.option_1.label"
        },
        {
          "value": "image_second",
          "label": "t:sections.hotspot.settings.imgae_layout.option_2.label"
        }
      ],
      "default": "image_first",
      "label": "t:sections.hotspot.settings.imgae_layout.label"

    },
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },

  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "t:sections.hotspot.blocks.hotspot_block.name",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "prodimg",
          "label":"Image",
        },
        {
          "type": "product",
          "id": "product",
          "label":"t:sections.hotspot.blocks.hotspot_block.settings.product.label",
        },
         {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.hotspot.blocks.hotspot_block.settings.show_dynamic_checkout.label",
          "info": "t:sections.hotspot.blocks.hotspot_block.settings.show_dynamic_checkout.info"
        },
         {
          "type": "text",
          "id": "tag_name",
          "label":"t:sections.hotspot.blocks.hotspot_block.settings.tag.label",
           "default":"t:sections.hotspot.blocks.hotspot_block.settings.tag.default",
           "info":"t:sections.hotspot.blocks.hotspot_block.settings.tag.info"
        },
        {
          "type": "color",
          "id": "tag_color",
          "label":"t:sections.hotspot.blocks.hotspot_block.settings.tag_color.label"
           },
         {
          "type": "color",
          "id": "tag_background_color",
          "label":"t:sections.hotspot.blocks.hotspot_block.settings.tag_background_color.label"
           },
        {
          "type": "range",
          "id": "horizontal_position",
           "label":"t:sections.hotspot.blocks.hotspot_block.settings.horizontal_position.label",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "vertical_position",
           "label":"t:sections.hotspot.blocks.hotspot_block.settings.vertical_position.label",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }


      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.hotspot.presets.name",
      "blocks": [
        {
          "type": "hotspot"
        },
         {
          "type": "hotspot"
        },
         {
          "type": "hotspot"
        }
      ]
    }
  ]
}
{% endschema %}
