        r && (e.forEach((t => {
            t.classList.remove("active");
        })), r.classList.add("active"));
    }
    e.forEach((s => {
        s.addEventListener("click", (function() {
            let s = this.dataset.attr;
            a.forEach((t => {
                t.classList.remove("active");
            }));
            let i = t.querySelector(`.slider[data-attr="${s}"]`);
            i && i.classList.add("active"), c.forEach((t => {
                t.classList.remove("active");
            }));
            let l = t.querySelector(`.dot[data-slide="${s}"]`);
