function initSlider(t) {
    let e = t.querySelectorAll(".hotspot");
let a = t.querySelectorAll(".slider");
let c = t.querySelectorAll(".dot");
    function s(s) {
        a.forEach((t => {
            t.classList.remove("active");
        })), c.forEach((t => {
            t.classList.remove("active");
        }));
        let i = t.querySelector(`.slider[data-attr="${s + 1}"]`);
        i && i.classList.add("active");
